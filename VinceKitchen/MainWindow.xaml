<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:VinceApp="clr-namespace:VinceApp;assembly=VinceApp" x:Class="VinceKitchen.MainWindow"
        Title="شاشة المطبخ" Height="800" Width="1200" WindowStyle="None"
        WindowState="Maximized" Background="#212121" FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#333" BorderBrush="#444" BorderThickness="0,0,0,1">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Width="45" Height="45" Background="#D32F2F" BorderThickness="0" Click="ExitButton_Click" Margin="0,0,15,0">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                                <TextBlock Text="X" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#B71C1C"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#FF5252"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="👨‍🍳" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="شاشة تحضير الطلبات" 
                               FontSize="28" FontWeight="Bold" Foreground="#EEE" 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="StatusBorder" Width="15" Height="15" CornerRadius="10" 
                            Background="LimeGreen" Margin="0,0,15,0" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="#00E676" BlurRadius="8" ShadowDepth="0"/>
                        </Border.Effect>
                        <Border.ToolTip>
                            <ToolTip  Content="حالة الاتصال بالسيرفر"/>
                        </Border.ToolTip>
                    </Border>


                    <VinceApp:DigitalClock />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <ItemsControl x:Name="OrdersList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="300" Margin="10" Background="#424242" CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="10"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>

                                <Border Background="#FF9800" CornerRadius="8,8,0,0" Padding="10">
                                    <TextBlock Text="{Binding TableNumberDisplay}" 
                                               FontSize="24" FontWeight="Bold" Foreground="White" 
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Row="1" Text="{Binding TimeDisplay}" 
                                           Foreground="#BBB" HorizontalAlignment="Center" Margin="0,5"/>

                                <ItemsControl Grid.Row="2" ItemsSource="{Binding KitchenItems}" Margin="10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#555" BorderThickness="0,0,0,1" Padding="5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding ProductName}" FontSize="20" Foreground="White" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat=x\{0\}}" FontSize="20" Foreground="#FFC107" FontWeight="Bold"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Grid.Row="3" Content="✅ جاهز" 
                                        Background="#4CAF50" Foreground="White"
                                        FontSize="22" FontWeight="Bold"
                                        Tag="{Binding OrderId}" Click="OrderDone_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="0,0,8,8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>