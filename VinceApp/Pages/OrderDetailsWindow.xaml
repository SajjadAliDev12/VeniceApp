<Window x:Class="VinceApp.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تفاصيل الفاتورة" Height="500" Width="600"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        FlowDirection="RightToLeft" Background="#F9F9F9">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock x:Name="txtTitle" Text="فاتورة رقم #1234" FontSize="22" FontWeight="Bold" Foreground="#3E2723"/>
            <TextBlock x:Name="txtDate" Text="التاريخ: 2025/01/01" FontSize="14" Foreground="Gray"/>
        </StackPanel>

        <DataGrid x:Name="dgDetails" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  HeadersVisibility="Column" Background="White" RowHeight="35" BorderThickness="1" BorderBrush="#EEE">
            <DataGrid.Columns>
                <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="السعر" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="80"/>
                <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="60"/>
                <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total, StringFormat={}{0:N0}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="إغلاق" Height="40" Width="100" Margin="0,15,0,0"
                Background="#5D4037" Foreground="White" Click="Close_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>