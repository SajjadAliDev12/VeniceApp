<Window x:Class="VinceApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:VinceApp"
        Title="حلويات البندقية" 
        WindowState="Maximized" 
        WindowStyle="None" 
        ResizeMode="NoResize" 
        Topmost="False"
        Background="#F9F5F0" FlowDirection="RightToLeft">

    <Window.Resources>
        <local:ImagePathConverter x:Key="ImgConverter"/>
        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5D4037"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="catBorder" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="catBorder" Property="Background" Value="#8D6E63"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NumpadButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="#DDD" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="396"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Button HorizontalAlignment="Left" Click="ExitButton_Click" Width="50" Height="40" Background="#D32F2F" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <TextBlock Text="X" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <local:DigitalClock Width="150" Height="50" HorizontalAlignment="Right"> </local:DigitalClock>
                <TextBlock x:Name="Title" Text="حلويات البندقية" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" FontWeight="Bold" Foreground="#5D4037"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="White" Margin="10,10,10,10" CornerRadius="15" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="الطلب الحالي" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                <ListBox x:Name="lstCart" Grid.Row="1" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="5" Margin="0,5">
                                <Grid Width="320">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0:N0} د.ع'}" Foreground="Gray" FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="-" Width="35" Height="35" Background="#FFEBEE" Foreground="#D32F2F" FontWeight="Bold" FontSize="18" BorderThickness="0" Click="DecreaseQty_Click" Tag="{Binding ProductId}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="17"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <TextBlock Text="{Binding Quantity}" Width="30" TextAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                                        <Button Content="+" Width="35" Height="35" Background="#E8F5E9" Foreground="#2E7D32" FontWeight="Bold" FontSize="18" BorderThickness="0" Click="IncreaseQty_Click" Tag="{Binding ProductId}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="17"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2" BorderBrush="#EEE" BorderThickness="0,1,0,0" Padding="0,15,0,0">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,5">
                            <TextBlock Text="المجموع الكلي" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtTotal" Text="0 د.ع" DockPanel.Dock="Left" FontSize="24" FontWeight="Bold" Foreground="#2E7D32"/>
                        </DockPanel>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnConfirm" Content="حفظ وتأكيد" Height="65" Background="#1976D2" Foreground="White" 
                                    FontSize="20" FontWeight="Bold" Margin="0,0,5,0" Click="ConfirmOrder_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnPay" Grid.Column="1" Content="إتمام الدفع" Height="65" Background="#2E7D32" Foreground="White" 
                                    FontSize="24" FontWeight="Bold" Margin="5,0,0,0" Click="PayButton_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Grid.Column="1" PanningMode="Both" VerticalScrollBarVisibility="Hidden">
            <ItemsControl x:Name="itemsControlProducts" Margin="10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="180" Height="260" Margin="8" Background="White" Click="Product_Click" IsEnabled="{Binding IsAvailable}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="White" CornerRadius="15" BorderBrush="#EEE" BorderThickness="1">
                                        <StackPanel VerticalAlignment="Top">
                                            <Image CacheMode="BitmapCache" Source="{Binding ImagePath, Converter={StaticResource ImgConverter},IsAsync=True,TargetNullValue='pack://application:,,,/Images/default.jpg'}" 
       Height="140" Stretch="UniformToFill"/>
                                            <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="5,10,5,0"/>
                                            <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} د.ع'}" HorizontalAlignment="Center" Foreground="#2E7D32" FontWeight="SemiBold" Margin="0,5,0,10"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                            <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#CCC"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#FFF8E1"/>
                                            <Setter TargetName="border" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="90" CenterY="130"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="2" Margin="5,5,5,5">
            <ScrollViewer VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly">
                <ItemsControl x:Name="icCategories">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}" Style="{StaticResource CategoryButtonStyle}" Click="Category_Click" Tag="{Binding Name}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid x:Name="PaymentOverlay" Grid.RowSpan="2" Grid.ColumnSpan="3" Visibility="Collapsed" Background="#B2000000">
            <Border Background="#F9F5F0" Width="550" Height="700" CornerRadius="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="نافذة الدفع" HorizontalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="#5D4037" Margin="0,0,0,20"/>
                    <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20" BorderBrush="#EEE" BorderThickness="1">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="المبلغ المطلوب:" FontSize="20" Foreground="#555"/>
                                <TextBlock x:Name="txtOverlayTotal" Text="0" FontSize="24" FontWeight="Bold" Foreground="#5D4037" DockPanel.Dock="Left"/>
                            </DockPanel>
                            <Separator Background="#EEE" Margin="0,5"/>
                            <DockPanel Margin="0,10,0,10">
                                <TextBlock Text="المدفوع:" FontSize="22" Foreground="#333" FontWeight="SemiBold"/>
                                <Border Background="#FAFAFA" CornerRadius="5" BorderBrush="#2E7D32" BorderThickness="1" Padding="5,0" Width="200" HorizontalAlignment="Left">
                                    <TextBlock x:Name="txtPaidAmount" Text="0" FontSize="28" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Border>
                            </DockPanel>
                            <Separator Background="#EEE" Margin="0,5"/>
                            <DockPanel Margin="0,10,0,0">
                                <TextBlock Text="الباقي للزبون:" FontSize="20" Foreground="#555"/>
                                <TextBlock x:Name="txtChangeAmount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#D32F2F" DockPanel.Dock="Left"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="2" Margin="40,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Button Content="7" Grid.Row="0" Grid.Column="0" Style="{StaticResource NumpadButtonStyle}" Click="Numpad_Click"/>
                        <Button Content="8" Grid.Row="0" Grid.Column="1" Style="{StaticResource NumpadButtonStyle}" Click="Numpad_Click"/>
                        <Button Content="9" Grid.Row="0" Grid.Column="2" Style="{StaticResource NumpadButtonStyle}" Click="Numpad_Click"/>
                        <Button Content="4" Grid.Row="1" Grid.Column="0" Style="{StaticResource NumpadButtonStyle}" Click="Numpad_Click"/>
                        <Button Content="5" Grid.Row="1" Grid.Column="1" Style="{StaticResource NumpadButtonStyle}" Click="Numpad_Click"/>
                        <Button Content="6" Grid.Row="1" Grid.Column="2" Style="{StaticResource NumpadButtonStyle}" Click="Numpad_Click"/>
                        <Button Content="1" Grid.Row="2" Grid.Column="0" Style="{StaticResource NumpadButtonStyle}" Click="Numpad_Click"/>
                        <Button Content="2" Grid.Row="2" Grid.Column="1" Style="{StaticResource NumpadButtonStyle}" Click="Numpad_Click"/>
                        <Button Content="3" Grid.Row="2" Grid.Column="2" Style="{StaticResource NumpadButtonStyle}" Click="Numpad_Click"/>
                        <Button Content="C" Grid.Row="3" Grid.Column="0" Style="{StaticResource NumpadButtonStyle}" Foreground="#D32F2F" Click="Numpad_Clear_Click"/>
                        <Button Content="0" Grid.Row="3" Grid.Column="1" Style="{StaticResource NumpadButtonStyle}" Click="Numpad_Click"/>
                        <Button Content="⌫" Grid.Row="3" Grid.Column="2" Style="{StaticResource NumpadButtonStyle}" FontSize="20" Click="Numpad_Backspace_Click"/>
                    </Grid>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="إلغاء" Width="120" Height="50" Background="#E0E0E0" Foreground="#333" FontSize="18" FontWeight="Bold" Margin="10,0" Click="CloseOverlay_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="طباعة الوصل" Width="250" Height="50" Background="#5D4037" Foreground="White" FontSize="18" FontWeight="Bold" Margin="10,0" Click="PrintReceipt_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>