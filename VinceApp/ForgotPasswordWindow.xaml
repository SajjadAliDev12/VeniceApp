<Window x:Class="VinceApp.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="استعادة كلمة المرور" Height="500" Width="450"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent"
        FlowDirection="RightToLeft">

    <Border Background="White" CornerRadius="15" BorderBrush="#5D4037" BorderThickness="2">
        <Grid Margin="20">
            <StackPanel>
                <TextBlock Text="🔑 استعادة الحساب" FontSize="22" FontWeight="Bold" Foreground="#5D4037" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="اسم المستخدم:" Foreground="Gray"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,15">
                    <TextBox x:Name="txtUsername" Width="240" Height="35" FontSize="14" Padding="5"/>
                    <Button Content="بحث" Width="100" Margin="10,0,0,0" Background="#2196F3" Foreground="White" Click="Search_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <StackPanel x:Name="pnlReset" Visibility="Collapsed">
                    <TextBlock Text="سؤال الأمان:" Foreground="#1976D2" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock x:Name="lblQuestion" Text="---" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,15" Foreground="#333"/>

                    <TextBlock Text="إجابة السؤال:" Foreground="Gray"/>
                    <TextBox x:Name="txtAnswer" Height="35" FontSize="14" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Text="كلمة المرور الجديدة:" Foreground="Gray"/>
                    <PasswordBox x:Name="txtNewPass" Height="35" FontSize="14" Padding="5" Margin="0,0,0,10"/>

                    <Button Content="تغيير كلمة المرور" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="0,10,0,0" Click="ResetPassword_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Button Content="إلغاء وإغلاق" Height="35" Background="Transparent" Foreground="#777" Margin="0,15,0,0" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>